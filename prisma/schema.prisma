generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  phone     String?  @unique
  email     String?  @unique
  name      String?
  password  String?
  role      UserRole @default(USER)
  provider  String?

  otpCode       String?
  otpExpiresAt  DateTime?
  otpAttempts   Int      @default(0)
  phoneVerified Boolean  @default(false)
  emailVerified Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submissions AdSubmission[]
  audits      AuditLog[]

  @@index([phone])
  @@index([email])
}

model Category {
  id          String  @id @default(cuid())
  name        String  @unique
  nameAr      String
  slug        String  @unique
  icon        String?
  description String?
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submissions AdSubmission[]
}

model Package {
  id               String  @id @default(cuid())
  name             String  @unique
  nameAr           String
  description      String?
  price            Int
  durationDays     Int     @default(7)
  maxImages        Int     @default(2)
  isFeatured       Boolean @default(false)
  isPinned         Boolean @default(false)
  includesTelegram Boolean @default(false)
  isActive         Boolean @default(true)
  sortOrder        Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submissions AdSubmission[]
}

model AdSubmission {
  id             String    @id @default(cuid())
  phone          String
  language       String?
  categoryId     String?
  category       Category? @relation(fields: [categoryId], references: [id])
  categoryName   String?
  text           String?
  title          String?
  contactPhone   String?
  whatsappNumber String?
  telegramChatId   String?
  telegramUsername String?
  contactEmail     String?
  contactMethod    String?
  contentType      String    @default("ad")

  offerStartDate DateTime?
  offerEndDate   DateTime?
  bookingEnabled Boolean   @default(false)
  bookingType    String?

  images      String[]
  imagesCount Int      @default(0)

  priceText   Float?
  priceImages Float?
  priceTotal  Float?

  packageId String?
  package   Package? @relation(fields: [packageId], references: [id])

  status        SubmissionStatus @default(DRAFT)
  publishTarget String           @default("website")

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  adPrice      Int?
  isNegotiable Boolean @default(false)

  payment         Payment?
  ad              Ad?
  submissionMedia SubmissionMedia[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@index([status])
  @@index([userId])
}

model Ad {
  id           String       @id @default(cuid())
  submissionId String       @unique
  submission   AdSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  title       String?
  description String
  category    String
  contentType String  @default("ad")

  offerStartDate DateTime?
  offerEndDate   DateTime?
  bookingEnabled Boolean   @default(false)
  bookingType    String?

  contactPhone     String?
  whatsappNumber   String?
  telegramChatId   String?
  telegramUsername String?
  contactEmail     String?
  contactMethod    String?

  isFeatured Boolean @default(false)
  isPinned   Boolean @default(false)

  status      AdStatus @default(PENDING)
  expiresAt   DateTime
  publishedAt DateTime?

  viewsCount     Int @default(0)
  whatsappClicks Int @default(0)
  callClicks     Int @default(0)
  bookingClicks  Int @default(0)

  adPrice      Int?
  isNegotiable Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  media Media[]

  @@index([category])
  @@index([status])
  @@index([isFeatured])
  @@index([contentType])
}

model Media {
  id       String @id @default(cuid())
  adId     String
  url      String
  position Int

  createdAt DateTime @default(now())

  ad Ad @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@unique([adId, position])
}

model SubmissionMedia {
  id           String       @id @default(cuid())
  submissionId String
  submission   AdSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  tempKey   String
  position  Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([submissionId, position])
  @@index([submissionId])
  @@index([expiresAt])
}

model Payment {
  id String @id @default(cuid())

  submissionId String       @unique
  submission   AdSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  provider    String
  amount      Float
  currency    String
  status      PaymentStatus

  providerRef String @unique
  rawPayload  Json?

  createdAt DateTime @default(now())

  @@index([providerRef])
}

model PricingConfig {
  id             String  @id @default(cuid())
  textPrice      Int
  imagePrice     Int
  adDurationDays Int

  freeAutoPublish    Boolean @default(false)
  freeRequiresReview Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  updatedAt DateTime @updatedAt
}

model OtpRequest {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  attempts  Int      @default(0)

  createdAt DateTime @default(now())

  @@index([phone])
}

model AuditLog {
  id String @id @default(cuid())

  userId    String?
  actor     String

  action   String
  entity   String
  entityId String?

  payload   Json?
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

enum SubmissionStatus {
  DRAFT
  WAITING_PAYMENT
  PAID
  PENDING_REVIEW
  PUBLISHED
  PUBLISHED_PARTIAL
  REJECTED
  EXPIRED
}

enum AdStatus {
  PENDING
  APPROVED
  REJECTED
  PUBLISHED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum UserRole {
  USER
  ADMIN
  SUPERVISOR
}
