generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String   @id @default(cuid())
  phone    String?  @unique
  email    String?  @unique
  username String?  @unique
  name     String?
  password String?
  role     UserRole @default(USER)
  userType UserType @default(PERSONAL)
  provider String?

  otpCode       String?
  otpExpiresAt  DateTime?
  otpAttempts   Int       @default(0)
  phoneVerified Boolean   @default(false)
  emailVerified Boolean   @default(false)

  // 2FA (TOTP) — for admin accounts
  twoFactorSecret  String?
  twoFactorEnabled Boolean @default(false)

  // Session timeout tracking
  lastActivityAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submissions AdSubmission[]
  audits      AuditLog[]
  company     Company?

  @@index([phone])
  @@index([email])
  @@index([username])
}

model Category {
  id          String  @id @default(cuid())
  name        String  @unique
  nameAr      String
  slug        String  @unique
  icon        String?
  imageUrl    String?
  description String?
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  parentId String?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submissions AdSubmission[]

  @@index([parentId])
}

model Package {
  id               String    @id @default(cuid())
  name             String    @unique
  nameAr           String
  description      String?
  price            Int
  durationDays     Int       @default(7)
  maxChars         Int       @default(300)
  maxImages        Int       @default(2)
  isFeatured       Boolean   @default(false)
  isPinned         Boolean   @default(false)
  includesTelegram Boolean   @default(false)
  isActive         Boolean   @default(true)
  sortOrder        Int       @default(0)
  promoEndDate     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submissions AdSubmission[]
}

model AdSubmission {
  id               String    @id @default(cuid())
  phone            String
  language         String?
  categoryId       String?
  category         Category? @relation(fields: [categoryId], references: [id])
  categoryName     String?
  text             String?
  title            String?
  contactPhone     String?
  whatsappNumber   String?
  telegramChatId   String?
  telegramUsername String?
  contactEmail     String?
  contactMethod    String?
  contentType      String    @default("ad")
  location         String?
  subCategory      String?

  offerStartDate DateTime?
  offerEndDate   DateTime?
  bookingEnabled Boolean   @default(false)
  bookingType    String?

  images      String[]
  imagesCount Int      @default(0)

  priceText   Float?
  priceImages Float?
  priceTotal  Float?

  packageId String?
  package   Package? @relation(fields: [packageId], references: [id])

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  status        SubmissionStatus @default(DRAFT)
  publishTarget String           @default("website")
  /**
   * Origin channel — used by the payment webhook to know whom to DM with links.
   */
  source        String? // "web" | "telegram" | "whatsapp"

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  adPrice      Int?
  isNegotiable Boolean @default(false)

  payment         Payment?
  ad              Ad?
  submissionMedia SubmissionMedia[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@index([status])
  @@index([userId])
}

model Ad {
  id           String       @id @default(cuid())
  submissionId String       @unique
  submission   AdSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  title       String?
  description String
  category    String
  contentType String  @default("ad")

  offerStartDate DateTime?
  offerEndDate   DateTime?
  bookingEnabled Boolean   @default(false)
  bookingType    String?

  contactPhone     String?
  whatsappNumber   String?
  telegramChatId   String?
  telegramUsername String?
  contactEmail     String?
  contactMethod    String?
  location         String?
  subCategory      String?

  isFeatured Boolean @default(false)
  isPinned   Boolean @default(false)

  status      AdStatus  @default(PENDING)
  expiresAt   DateTime
  publishedAt DateTime?

  viewsCount     Int @default(0)
  whatsappClicks Int @default(0)
  callClicks     Int @default(0)
  bookingClicks  Int @default(0)

  adPrice      Int?
  isNegotiable Boolean @default(false)

  telegramMessageId String?
  facebookPostId    String?
  instagramPostId   String?
  twitterPostId     String?

  // Soft-delete: admin can restore within 7 days, cron purges after
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  media Media[]

  @@index([category])
  @@index([status])
  @@index([isFeatured])
  @@index([contentType])
}

model Media {
  id       String @id @default(cuid())
  adId     String
  url      String
  position Int

  createdAt DateTime @default(now())

  ad Ad @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@unique([adId, position])
}

model SubmissionMedia {
  id           String       @id @default(cuid())
  submissionId String
  submission   AdSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  tempKey   String
  position  Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([submissionId, position])
  @@index([submissionId])
  @@index([expiresAt])
}

model Payment {
  id String @id @default(cuid())

  submissionId String?       @unique
  submission   AdSubmission? @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  // Company subscription payment (mutually exclusive with submissionId)
  companyId String?
  company   Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  purpose   PaymentPurpose @default(AD_PAYMENT)

  provider String
  amount   Float
  currency String
  status   PaymentStatus

  providerRef String @unique
  rawPayload  Json?

  createdAt DateTime @default(now())

  @@index([providerRef])
  @@index([companyId])
}

model PricingConfig {
  id             String @id @default(cuid())
  textPrice      Int
  imagePrice     Int
  adDurationDays Int

  freeAutoPublish    Boolean @default(false)
  freeRequiresReview Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  updatedAt DateTime @updatedAt
}

model OtpRequest {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  attempts  Int      @default(0)

  createdAt DateTime @default(now())

  @@index([phone])
}

model AdReport {
  id            String    @id @default(cuid())
  adId          String
  adTitle       String?
  adUrl         String
  reporterName  String?
  reporterEmail String?
  reporterPhone String?
  reason        String
  details       String?
  status        String    @default("PENDING")
  createdAt     DateTime  @default(now())
  reviewedAt    DateTime?
  reviewedBy    String?

  @@index([adId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
}

model BlogArticle {
  id              String   @id @default(cuid())
  slug            String   @unique
  language        String // "ar" | "en"
  /**
   * Shared identifier across language pairs of the same topic.
   */
  topicSlug       String?
  title           String
  metaTitle       String
  metaDescription String
  keywords        String[]
  excerpt         String?
  content         String // markdown
  coverImageUrl   String?
  /**
   * Provenance of the article — "AI" or "MANUAL".
   */
  source          String   @default("AI")
  /**
   * "PUBLISHED" or "DRAFT". Drafts hidden from public listing.
   */
  status          String   @default("PUBLISHED")
  publishDate     DateTime @default(now())
  viewsCount      Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([language, status])
  @@index([publishDate(sort: Desc)])
  @@index([topicSlug])
}

model PromoLog {
  id           String   @id @default(cuid())
  platform     String
  contentIndex Int
  postId       String?
  postUrl      String?
  status       String   @default("SUCCESS")
  errorMessage String?
  publishedAt  DateTime @default(now())

  @@index([platform, publishedAt(sort: Desc)])
}

model AuditLog {
  id String @id @default(cuid())

  userId String?
  actor  String

  action   String
  entity   String
  entityId String?

  payload   Json?
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

enum SubmissionStatus {
  DRAFT
  WAITING_PAYMENT
  PAID
  PENDING_REVIEW
  PUBLISHED
  PUBLISHED_PARTIAL
  REJECTED
  EXPIRED
}

enum AdStatus {
  PENDING
  APPROVED
  REJECTED
  PUBLISHED
  SUSPENDED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum UserRole {
  USER
  ADMIN
  CONTENT_ADMIN
  SUPERVISOR
}

enum UserType {
  PERSONAL
  COMPANY
}

enum PaymentPurpose {
  AD_PAYMENT
  COMPANY_SUBSCRIPTION
}

enum CompanySubscriptionStatus {
  PENDING_OTP
  PENDING_PAYMENT
  ACTIVE
  EXPIRED
  CANCELLED
}

model CompanyPlan {
  id            String  @id @default(cuid())
  slug          String  @unique
  name          String  @unique
  nameAr        String
  description   String?
  descriptionAr String?

  price        Float
  currency     String @default("AED")
  billingCycle String @default("MONTHLY")

  maxActivities Int     @default(1)
  maxAdChars    Int
  maxAdImages   Int
  unlimitedAds  Boolean @default(true)

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies Company[]
}

model Company {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tradeLicenseName    String
  tradeLicenseUrl     String
  companyPhone        String
  authorizedSignatory String
  activity            String

  username String @unique

  planId String?
  plan   CompanyPlan? @relation(fields: [planId], references: [id])

  subscriptionStatus    CompanySubscriptionStatus @default(PENDING_OTP)
  subscriptionStartedAt DateTime?
  subscriptionEndsAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments    Payment[]
  submissions AdSubmission[]

  @@index([username])
  @@index([subscriptionStatus])
  @@index([companyPhone])
}
